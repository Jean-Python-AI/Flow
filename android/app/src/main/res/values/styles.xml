<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Thème de base de l'app (parent correct !) -->
  <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
    <!-- Status bar opaque et pousse le contenu -->
    <item name="android:windowTranslucentStatus">false</item>
    <item name="android:windowTranslucentNavigation">false</item>
    <item name="android:fitsSystemWindows">true</item>
    <!-- <item name="android:statusBarColor">@color/splashscreen_background</item> Modifie le style de la barre statut -->
    <item name="android:navigationBarColor">@color/splashscreen_background</item>
    <item name="android:windowFullscreen">false</item>
    <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
  </style>

    <style name="SplashTheme" parent="AppTheme">
        <item name="android:windowBackground">@drawable/splash</item>  <!-- Pointe vers splash.xml -->
        <item name="android:windowFullscreen">false</item>  <!-- Optionnel, pour full screen -->
    </style>
</resources>
